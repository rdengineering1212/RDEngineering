# ═══════════════════════════════════════════════════════════════════
#  RD Engineering — Environment Variables
#  Copy this file to .env.local and fill in your real values.
#  Never commit .env.local to git.
# ═══════════════════════════════════════════════════════════════════

# ───────────────────────────────────────────────────────────────────
# DATABASE (Supabase PostgreSQL)
# ───────────────────────────────────────────────────────────────────
# Go to: Supabase Dashboard → Project → Settings → Database → Connection String
#
# DATABASE_URL  → Use the "Transaction" string (port 6543, pgbouncer=true)
#   This is used by your app at runtime via connection pooling.
#
# DIRECT_URL    → Use the "Direct" string (port 5432, no pgbouncer)
#   This is used by Prisma for migrations ONLY.
#
DATABASE_URL="postgresql://postgres.YOURPROJECT:YOURPASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.YOURPROJECT:YOURPASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:5432/postgres"

# ───────────────────────────────────────────────────────────────────
# SUPABASE SDK (for client-side Supabase features)
# ───────────────────────────────────────────────────────────────────
# Go to: Supabase Dashboard → Project → Settings → API
#
NEXT_PUBLIC_SUPABASE_URL="https://YOURPROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."
SUPABASE_SERVICE_ROLE_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9..."

# ───────────────────────────────────────────────────────────────────
# EMAIL — Resend (Recommended, primary provider)
# ───────────────────────────────────────────────────────────────────
# Sign up at: https://resend.com
# After signup: API Keys → Create Key → paste below
#
# IMPORTANT: Without a verified domain in Resend, you can only send
# emails to the email address registered on Resend.com itself.
# To send admin notifications to rdengineering1212@gmail.com:
#   Option A: Verify your domain at Resend (add DNS TXT records)
#   Option B: Use SMTP with Gmail App Password (see below)
#
RESEND_API_KEY="re_YOUR_API_KEY_HERE"
RESEND_FROM_EMAIL="noreply@yourdomain.com"
# If domain not verified yet, use: RESEND_FROM_EMAIL="onboarding@resend.dev"

# ───────────────────────────────────────────────────────────────────
# EMAIL — SMTP / Gmail (Fallback or alternative to Resend)
# ───────────────────────────────────────────────────────────────────
# How to get Gmail App Password:
#   1. Go to: https://myaccount.google.com/security
#   2. Enable 2-Step Verification
#   3. Search for "App passwords"
#   4. Generate → "Mail" → Copy the 16-character password
#   5. Paste that password as SMTP_PASS (NOT your normal Gmail password)
#
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER="rdengineering1212@gmail.com"
SMTP_PASS="xxxx xxxx xxxx xxxx"
SMTP_FROM="rdengineering1212@gmail.com"

# ───────────────────────────────────────────────────────────────────
# WHATSAPP BUSINESS CLOUD API
# ───────────────────────────────────────────────────────────────────
# How to set up:
#   1. Go to: https://developers.facebook.com → Create App → Business
#   2. Add "WhatsApp" product to your app
#   3. Go to: WhatsApp → API Setup
#   4. Copy the "Temporary access token" (valid 24h) or generate a permanent system user token
#   5. Copy the "Phone Number ID"
#   6. In test mode: the recipient (+91 8883389766) must be added to the allowed recipients list
#   7. For production: your business number must be approved by Meta
#
# Dashboard: https://business.facebook.com/wa/manage/phone-numbers/
#
WHATSAPP_ACCESS_TOKEN="EAAxxxxxxxxxxxxxxxxxx"
WHATSAPP_PHONE_NUMBER_ID="12345678901234"
WHATSAPP_ADMIN_RECIPIENT_NUMBER="918883389766"
# Note: recipient number must include country code, no + or spaces

# ───────────────────────────────────────────────────────────────────
# ADMIN PANEL AUTHENTICATION
# ───────────────────────────────────────────────────────────────────
# JWT_SECRET: Any random 32+ character string.
#   Generate one: openssl rand -hex 32
#
JWT_SECRET="your-super-secret-jwt-key-minimum-32-characters-long"

# Admin login credentials
ADMIN_USERNAME="admin"

# ADMIN_PASSWORD_HASH: bcrypt hash of your chosen password
#   Generate: node -e "const b=require('bcryptjs');b.hash('YourPassword123',12).then(h=>console.log(h))"
#   (install bcryptjs first: npm install bcryptjs)
ADMIN_PASSWORD_HASH="$2b$12$your_bcrypt_hash_here"

# ───────────────────────────────────────────────────────────────────
# SITE / COMPANY INFO
# ───────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL="https://yourdomain.com"
NEXT_PUBLIC_COMPANY_NAME="RD Engineering"
NEXT_PUBLIC_COMPANY_PHONE="8883389766"
NEXT_PUBLIC_COMPANY_EMAIL="rdengineering1212@gmail.com"
NEXT_PUBLIC_COMPANY_ADDRESS="4/372 Nehru Street, Dr Ambedkar Nagar, Kadambathur, Tamil Nadu 631209"

# Admin email (where form submissions are sent)
ADMIN_EMAIL="rdengineering1212@gmail.com"
ADMIN_PHONE="8883389766"
ADMIN_WHATSAPP="918883389766"

# ───────────────────────────────────────────────────────────────────
# DEPLOYMENT PLATFORM (Vercel / Railway / Render)
# ───────────────────────────────────────────────────────────────────
# On Vercel: Settings → Environment Variables → paste each variable above
# On Railway: Variables tab → paste each variable
# On Render: Environment → Environment Variables → paste each variable
#
# After adding all variables, redeploy your app.
# Then visit: https://yourdomain.com/api/health
# to verify all services are connected.
